# ── Hypurrmium Auto-Buy Backend ──

# Agent wallet private key (the wallet authorized to trade on users' behalf)
# Generate a new EOA specifically for this — NEVER reuse a personal wallet
AGENT_PRIVATE_KEY=0x...

# Your builder address (receives the builder fee on each order)
BUILDER_ADDRESS=0x...

# Builder approval max fee rate
BUILDER_APPROVAL_MAX_FEE_RATE=0.10%

# Server
PORT=3001

# CORS — comma-separated origins
CORS_ORIGINS=https://hypurrmium.xyz,http://localhost:3000,http://localhost:8080

# Database path
# Local default is ./autobuy.db
# In production use a persistent volume, for example: DB_PATH=/data/autobuy.db
# DB_PATH=/data/autobuy.db

# Fail startup in production if DB_PATH points to ephemeral app storage
# REQUIRE_PERSISTENT_DB=true

# Automatic DB backups
# Enabled by default when a backup directory can be resolved
# ENABLE_DB_BACKUPS=true
# DB_BACKUP_DIR=/data/backups
# DB_BACKUP_INTERVAL_MINUTES=60
# DB_BACKUP_MAX_FILES=168

# Resend email
RESEND_API_KEY=re_...
EMAIL_FROM=Hypurrmium <hypurrmium@hypurrmium.xyz>

# Admin dashboard key (required to access /admin.html)
ADMIN_KEY=

# Set to true to disable the worker (local dev)
DISABLE_WORKER=false
