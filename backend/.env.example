CORS_ORIGINS=https://hypurrmium.xyz,https://www.hypurrmium.xyz
DB_PATH=/data/autobuy.db
DISABLE_WORKER=true

# Optional but recommended
RESEND_API_KEY=
EMAIL_FROM=Hypurrmium <noreply@hypurrmium.xyz>
ADMIN_KEY=
BUILDER_ADDRESS=
BUILDER_APPROVAL_MAX_FEE_RATE=0.10%# ── Hypurrmium Auto-Buy Backend ──

# Agent wallet private key (the wallet authorized to trade on users' behalf)
# Generate a new EOA specifically for this — NEVER reuse a personal wallet
AGENT_PRIVATE_KEY=0x...

# Your builder address (receives the builder fee on each order)
BUILDER_ADDRESS=0x...

# Server
PORT=3001

# CORS — comma-separated origins
CORS_ORIGINS=https://hypurrmium.xyz,http://localhost:3000,http://localhost:8080

# Database path (optional, defaults to ./autobuy.db)
# DB_PATH=./autobuy.db

# Resend email
RESEND_API_KEY=re_...
EMAIL_FROM=Hypurrmium <hypurrmium@hypurrmium.xyz>

# Admin dashboard key (required to access /admin.html)
ADMIN_KEY=
